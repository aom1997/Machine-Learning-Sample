   },
   "outputs": [],
   "source": [
    "\n",
    "\n",
    "scale_pos_weight = len(Y_train[Y_train == 0]) / len(Y_train[Y_train == 1])\n",
    "print(f\"scale_pos_weight: {scale_pos_weight:.2f}\")\n",
    "\n",
    "model_lgbm = lgb.LGBMClassifier(\n",
    "    objective=\"binary\",\n",
    "    random_state=42,\n",
    "    learning_rate=0.05,\n",
    "    num_leaves=63,\n",
    "    n_estimators=2000,\n",
    "    min_child_samples=50,\n",
    "    reg_alpha=0.1,\n",
    "    reg_lambda=0.1,\n",
    "    feature_fraction=0.8,\n",
    "    bagging_fraction=0.8,\n",
    "    bagging_freq=5,\n",
    "    scale_pos_weight=scale_pos_weight,\n",
    "    importance_type=\"gain\",\n",
    ")\n",
    "\n",
    "model_lgbm.fit(\n",
    "    X_train, Y_train,\n",
    "    eval_set=[(X_valid, Y_valid)],\n",
    "    eval_metric=\"average_precision\",\n",
    "    callbacks=[\n",
    "        lgb.early_stopping(stopping_rounds=100),\n",
    "        lgb.log_evaluation(period=100),\n",
    "    ],\n",
    ")\n",
    "\n",
    "# Freeze the trained feature list — used by the pyfunc to select columns at scoring time\n",
    "train_cols = list(model_lgbm.booster_.feature_name())\n",
    "print(f\"\\nTrained on {len(train_cols)} features\")\n",
    "print(f\"Best iteration: {model_lgbm.booster_.best_iteration}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
