    "class DMEFraudModel(mlflow.pyfunc.PythonModel):\n",
    "    \"\"\"\n",
    "    Bundles preprocessing + LightGBM booster into one MLflow pyfunc.\n",
    "    \n",
    "    At inference time, callers pass a pandas DataFrame with raw claim feature\n",
    "    columns. The pyfunc:\n",
    "      1. Applies the same preprocessing used in training:\n",
    "         - fillna(999) on bene_days_last_claim\n",
    "         - replaces inf/-inf/NaN with 0 on numeric columns\n",
    "      2. Selects only the columns the model was trained on (by name).\n",
    "         Any extra columns in the input (e.g., risk_*, IDs, dates) are ignored.\n",
    "         Any missing columns are filled with 0.\n",
    "      3. Returns a 1D numpy array of P(fraud=1).\n",
    "    \"\"\"\n",
    "\n",
    "    #load model and save column sequence\n",
    "    def load_context(self, context):\n",
    "        import lightgbm as lgb\n",
    "        import json\n",
    "        # Load the saved booster\n",
    "        self._booster = lgb.Booster(model_file=context.artifacts[\"lgbm_model\"])\n",
    "        # Load the frozen feature list so predict() always sees the right columns in the right order\n",
    "        with open(context.artifacts[\"train_cols\"], \"r\") as f:\n",
    "            self._train_cols = json.load(f)\n",
    "\n",
    "    @staticmethod\n",
    "    def _preprocess(df: pd.DataFrame) -> pd.DataFrame:\n",
    "        df = df.copy()\n",
    "        # 1) bene_days_last_claim: fill NaN with 999\n",
    "        if \"bene_days_last_claim\" in df.columns:\n",
    "            df[\"bene_days_last_claim\"] = df[\"bene_days_last_claim\"].fillna(999)\n",
    "        # 2) inf -> NaN -> 0 on numeric columns\n",
    "        num_cols = df.select_dtypes(include=np.number).columns\n",
    "        df[num_cols] = df[num_cols].replace([np.inf, -np.inf], np.nan)\n",
    "        df[num_cols] = df[num_cols].fillna(0)\n",
    "        return df\n",
    "\n",
    "    def predict(self, context, model_input, params=None):\n",
    "        # Accept either a DataFrame or a dict-like; coerce to DataFrame\n",
    "        if not isinstance(model_input, pd.DataFrame):\n",
    "            model_input = pd.DataFrame(model_input)\n",
    "        \n",
    "        # Apply preprocessing\n",
    "        df = self._preprocess(model_input)\n",
    "        \n",
    "        # Select only the trained features by name, in the trained order\n",
    "        # Missing columns -> filled with 0 (defensive for production)\n",
    "        missing = [c for c in self._train_cols if c not in df.columns]\n",
    "        for c in missing:\n",
    "            df[c] = 0.0\n",
    "        X = df[self._train_cols]\n",
    "        \n",
    "        # Returns probabilities of class 1 (fraud)\n",
    "        return self._booster.predict(X)"
   ]
  },
