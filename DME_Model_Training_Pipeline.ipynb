     },
     "inputWidgets": {},
     "nuid": "e5f55f39-ffb2-47f3-9ccd-bff788c7b9d8",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "# Columns to drop: duplicate ID variants, payment amounts (data leakage)\n",
    "DROP_COLS_1st = [col for col in df_tran.columns if ('cur_clm_uniq_id_' in col) or ('paid_amt' in col)]\n",
    "\n",
    "# Drop patient-level payment ratio columns (data leakage)\n",
    "DROP_COLS_1st.extend([\n",
    "    'billnpibene_pct_paid_on_this_patient_365days',\n",
    "    'ordenpibene_pct_paid_on_this_patient_365days'\n",
    "])\n",
    "\n",
    "# Drop risk score and CPT string columns (data leakage)\n",
    "DROP_COLS_1st.extend([col for col in df_tran.columns if ('risk' in col)])\n",
    "\n",
    "df_tran = df_tran.drop(columns=DROP_COLS_1st)\n",
    "\n",
    "print(f'Dropped {len(DROP_COLS_1st)} columns: {DROP_COLS_1st}')\n",
    "\n",
    "#drop id columns before training\n",
    "Id_Cols = [\n",
    "    \"fraud_flag\",\n",
    "    \"cur_clm_uniq_id\",\n",
    "    \"clm_beneficiary_id\",\n",
    "    \"clm_billnpi\",\n",
    "    \"clm_ordenpi\",\n",
    "    \"clm_from_dt\",\n",
    "    \"clm_all_cpts\",\n",
    "    \"dataset\"\n",
    "]\n",
    "\n",
    "X = df_tran.drop(columns=Id_Cols)\n",
    "Y = df_tran[\"fraud_flag\"]\n",
    "\n",
    "print(f\"Dropped non-feature cols: {Id_Cols}\")\n",
    "print(f\"\\nPre-split X shape: {X.shape}  (still includes clm_thru_dt for splitting)\")\n",
    "print(f\"Y shape: {Y.shape},  positive rate: {Y.mean():.4%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "4d038eda-c835-441a-82da-3314adcee0f2",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "\n",
    "q1 = X[\"clm_thru_dt\"].quantile(0.70)\n",
    "q2 = X[\"clm_thru_dt\"].quantile(0.85)\n",
    "print(f\"Split points: q1={q1}  q2={q2}\")\n",
    "\n",
    "train_idx = X[\"clm_thru_dt\"] <= q1\n",
    "valid_idx = (X[\"clm_thru_dt\"] > q1) & (X[\"clm_thru_dt\"] <= q2)\n",
    "test_idx  = X[\"clm_thru_dt\"] > q2\n",
    "\n",
    "X_train = X[train_idx].drop(columns=[\"clm_thru_dt\"])\n",
    "Y_train = Y[train_idx]\n",
    "\n",
    "X_valid = X[valid_idx].drop(columns=[\"clm_thru_dt\"])\n",
    "Y_valid = Y[valid_idx]\n",
    "\n",
    "X_test  = X[test_idx].drop(columns=[\"clm_thru_dt\"])\n",
    "Y_test  = Y[test_idx]\n",
    "\n",
    "print(f\"\\nTrain %: {len(X_train)/len(X):.4f}  ({len(X_train):,} rows)\")\n",
    "print(f\"Valid %: {len(X_valid)/len(X):.4f}  ({len(X_valid):,} rows)\")\n",
    "print(f\"Test  %: {len(X_test)/len(X):.4f}   ({len(X_test):,} rows)\")\n",
    "\n",
    "total_pos = Y_train.sum() + Y_valid.sum() + Y_test.sum()\n",
    "print(f\"\\nPositive Train %: {Y_train.sum()/total_pos:.4f}  ({Y_train.sum():,} positives)\")\n",
    "print(f\"Positive Valid %: {Y_valid.sum()/total_pos:.4f}  ({Y_valid.sum():,} positives)\")\n",
    "print(f\"Positive Test  %: {Y_test.sum()/total_pos:.4f}  ({Y_test.sum():,} positives)\")\n",
    "\n",
    "print(f\"\\nFinal feature count: {X_train.shape[1]}\")"
   ]
  },
