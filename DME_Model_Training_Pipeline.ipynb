    }
   },
   "outputs": [],
   "source": [
    "\n",
    "# Identifiers + wide string column — keep as string\n",
    "KEEP_AS_STRING = [\n",
    "    \"clm_beneficiary_id\",\n",
    "    \"clm_billnpi\",\n",
    "    \"clm_ordenpi\",\n",
    "    \"clm_all_cpts\",\n",
    "    \"dataset\"\n",
    "]\n",
    "\n",
    "# Date columns\n",
    "DATE_COLS = [\"clm_from_dt\", \"clm_thru_dt\"]\n",
    "\n",
    "# fraud_flag is integer\n",
    "INT_COLS = [\"fraud_flag\",\"cur_clm_uniq_id\"]\n",
    "\n",
    "# Everything else: numeric (float64)\n",
    "all_cols = df_tran.columns.tolist()\n",
    "to_numeric = [c for c in all_cols\n",
    "              if c not in KEEP_AS_STRING\n",
    "              and c not in DATE_COLS\n",
    "              and c not in INT_COLS]\n",
    "\n",
    "print(f\"Casting {len(to_numeric)} columns to numeric\")\n",
    "print(f\"Keeping as string: {KEEP_AS_STRING}\")\n",
    "print(f\"Casting to datetime: {DATE_COLS}\")\n",
    "print(f\"Casting to int: {INT_COLS}\")\n",
    "\n",
    "# Cast numerics — errors='coerce' turns any non-numeric value into NaN\n",
    "for c in to_numeric:\n",
    "    df_tran[c] = pd.to_numeric(df_tran[c], errors=\"coerce\").astype(\"float32\")\n",
    "\n",
    "# Cast dates\n",
    "for c in DATE_COLS:\n",
    "    df_tran[c] = pd.to_datetime(df_tran[c], errors=\"coerce\")\n",
    "\n",
    "# Cast fraud_flag to int\n",
    "for c in INT_COLS:\n",
    "    df_tran[c] = pd.to_numeric(df_tran[c], errors=\"coerce\").fillna(0).astype(int)\n",
    "\n",
    "# Keep IDs as string explicitly\n",
    "for c in KEEP_AS_STRING:\n",
    "    df_tran[c] = df_tran[c].astype(\"object\")\n",
    "\n",
    "# Type distribution after cast\n",
    "print(\"\\nType distribution after cast:\")\n",
    "print(df_tran.dtypes.value_counts())\n",
    "\n",
    "# fraud_flag distribution\n",
    "print(\"\\nfraud_flag distribution:\")\n",
    "print(df_tran[\"fraud_flag\"].value_counts())\n",
    "print(f\"Fraud rate: {df_tran['fraud_flag'].mean():.4%}\")\n",
    "\n",
    "# Spot-check\n",
    "print(\"\\nSample values:\")\n",
    "print(df_tran[[\"clm_chrg_amt\", \"clm_paid_amt\", \"bene_days_last_claim\",\n",
    "               \"fraud_flag\", \"clm_thru_dt\"]].head())\n",
    "\n",
    "# Memory after cast\n",
    "print(f\"\\nMemory after cast: {df_tran.memory_usage(deep=True).sum()/1e9:.2f} GB\")"
   ]
  },
