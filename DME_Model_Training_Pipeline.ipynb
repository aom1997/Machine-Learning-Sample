   "source": [
    "# 1) bene_days_last_claim: fill NaN with 999\n",
    "df_tran[\"bene_days_last_claim\"] = df_tran[\"bene_days_last_claim\"].fillna(999)\n",
    "\n",
    "# 2) Replace inf/-inf with NaN, then fill all remaining NaN with 0\n",
    "df_tran[to_numeric] = df_tran[to_numeric].replace([np.inf, -np.inf], np.nan)\n",
    "df_tran[to_numeric] = df_tran[to_numeric].fillna(0)\n",
    "\n",
    "# Convert pandas Int64 → numpy int32\n",
    "\n",
    "# Sanity checks\n",
    "assert not np.isinf(df_tran[to_numeric].values).any(), \"Inf left after cleanup\"\n",
    "assert df_tran[to_numeric].isna().sum().sum() == 0, \"NaN left in numeric cols\"\n",
    "\n",
    "print(f\"Preprocessing OK — {len(num_cols)} numeric columns cleaned\")\n",
    "print(f\"Memory after preprocessing: {df_tran.memory_usage(deep=True).sum()/1e9:.2f} GB\")\n",
    "\n",
    "# Quick sanity: confirm clm_chrg_amt and clm_paid_amt aren't all-zero across the data\n",
    "print(f\"\\nclm_chrg_amt: mean={df_tran['clm_chrg_amt'].mean():.2f}, \"\n",
    "      f\"non-zero rows={ (df_tran['clm_chrg_amt'] != 0).sum():,}\")"
   ]
