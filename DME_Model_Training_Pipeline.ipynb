   "source": [
    "from google.cloud import bigquery\n",
    "from google.oauth2 import service_account\n",
    "\n",
    "USE_UC = False\n",
    "BQ_TABLE = \"your-gcp-project.ML_DATASETS.DME_Fraud_Training\"\n",
    "if USE_UC:\n",
    "    MODEL_NAME = \"your-gcp-project.dme_fraud.dme_lgbm_test\"\n",
    "else:\n",
    "    MODEL_NAME = \"dme_lgbm_test\"\n",
    "\n",
    "EXPERIMENT_PATH = \"/Users/your-email@your-org.com/machine_learning/fraud_dme/dme_lgbm_experiment\"\n",
    "\n",
    "PIP_REQUIREMENTS = [\n",
    "    \"lightgbm==4.3.0\",\n",
    "    \"pandas==2.2.2\",\n",
    "    \"numpy==1.26.4\",\n",
    "    \"scikit-learn==1.4.2\",\n",
    "]\n",
    "\n",
    ""import os\n",
    "from google.oauth2 import service_account\n",
    "\n",
    "# Load credentials from a local service account key file.\n",
    "# Set the environment variable GOOGLE_APPLICATION_CREDENTIALS to your key file path,\n",
    "# or replace the path below with your own key file location.\n",
    "# Never hardcode credentials in code.\n",
    "KEY_PATH = os.environ.get('GOOGLE_APPLICATION_CREDENTIALS', 'path/to/service_account.json')\n",
    "\n",
    "credentials = service_account.Credentials.from_service_account_file(\n",
    "    KEY_PATH,\n",
    "    scopes=['https://www.googleapis.com/auth/cloud-platform']\n",
    ")\n",
    "\n",
    "client = bigquery.Client(project=PROJECT_ID, credentials=credentials)\n",
    "\n",
    "# ── Query ───────────────────────────────────────────────────────────────────\n",
    "query = \"\"\"\n",
    "    SELECT a.*\n",
    "    FROM `your-gcp-project.ML_DATASETS.DME_Fraud_Training` a\n",
    "    JOIN `your-gcp-project.ML_DATASETS.fraud_dme_training_dataset` b\n",
    "      ON CAST(a.cur_clm_uniq_id AS STRING) = CAST(b.cur_clm_uniq_id AS STRING)\n",
    "\"\"\"\n",
    "\n",
    "df_tran = client.query(query).to_dataframe()\n",
    "print(f\"Rows: {df_tran.shape[0]:,}, Cols: {df_tran.shape[1]}\")"
   ]
  },
