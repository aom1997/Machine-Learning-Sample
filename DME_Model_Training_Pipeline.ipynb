   "source": [
    "\n",
    "CHAMPION_URI = f\"models:/{MODEL_NAME}@champion\"\n",
    "print(f\"Loading: {CHAMPION_URI}\")\n",
    "loaded = mlflow.pyfunc.load_model(CHAMPION_URI)\n",
    "print(\"✅ Loaded\")\n",
    "\n",
    "# ---- 0. Match the caller-side dtypes to the signature ----\n",
    "# v2's signature declares all numeric columns as float64 so callers can pass NaN.\n",
    "# X_valid/X_test still have int64 for some columns from the original split — cast\n",
    "# them to float64 before scoring, the same way Cell 10 did for the signature sample.\n",
    "int_cols_to_cast = X_valid.select_dtypes(include=\"integer\").columns\n",
    "X_valid_f64 = X_valid.astype({c: \"float64\" for c in int_cols_to_cast})\n",
    "X_test_f64  = X_test.astype({c: \"float64\" for c in int_cols_to_cast})\n",
    "print(f\"Cast {len(int_cols_to_cast)} int columns to float64 to match signature\")\n",
    "\n",
    "# ---- 1. Parity: pyfunc must match in-memory booster exactly ----\n",
    "preds_loaded = np.asarray(loaded.predict(X_valid_f64))\n",
    "preds_inmem  = model_lgbm.booster_.predict(X_valid_f64[train_cols])\n",
    "max_abs_diff = float(np.max(np.abs(preds_loaded - preds_inmem)))\n",
    "print(f\"Max |loaded - in-memory|: {max_abs_diff:.3e}\")\n",
    "assert max_abs_diff < 1e-9, f\"❌ Parity check failed ({max_abs_diff:.3e})\"\n",
    "print(\"✅ Parity check passed (< 1e-9)\")\n",
    "\n",
    "# ---- 2. Extra columns dropped silently ----\n",
    "X_valid_noisy = X_valid_f64.copy()\n",
    "X_valid_noisy[\"risk_garbage\"]     = 99.0\n",
    "X_valid_noisy[\"random_extra_col\"] = 1.0\n",
    "preds_noisy = np.asarray(loaded.predict(X_valid_noisy))\n",
    "assert np.allclose(preds_noisy, preds_loaded), \"❌ Extra columns not ignored\"\n",
    "print(\"✅ Extra columns dropped silently\")\n",
    "\n",
    "# # ---- 3. Missing columns filled with 0 (pyfunc's defensive feature) ----\n",
    "# cols_to_drop = train_cols[:5]\n",
    "# X_valid_missing = X_valid_f64.drop(columns=cols_to_drop)\n",
    "# preds_missing = np.asarray(loaded.predict(X_valid_missing))\n",
    "# assert np.all(np.isfinite(preds_missing)), \"❌ Non-finite preds when columns missing\"\n",
    "# print(f\"✅ Missing columns ({len(cols_to_drop)}) filled with 0 — predictions still finite\")\n",
    "\n",
    "# ---- 4. NaN and inf handling ----\n",
    "X_valid_dirty = X_valid_f64.copy().head(100)\n",
    "if \"bene_days_last_claim\" in X_valid_dirty.columns:\n",
    "    X_valid_dirty.iloc[0, X_valid_dirty.columns.get_loc(\"bene_days_last_claim\")] = np.nan\n",
    "num_col = X_valid_dirty.select_dtypes(include=np.number).columns[0]\n",
    "X_valid_dirty.iloc[0, X_valid_dirty.columns.get_loc(num_col)] = np.inf\n",
    "preds_dirty = np.asarray(loaded.predict(X_valid_dirty))\n",
    "assert np.all(np.isfinite(preds_dirty)), \"❌ Non-finite preds from NaN/inf input\"\n",
    "print(\"✅ NaN and inf handled (all outputs finite)\")\n",
    "\n",
    "# ---- 5. Signature column count ----\n",
    "sig = loaded.metadata.signature\n",
    "n_sig_inputs = len(sig.inputs.inputs) if sig else None\n",
    "print(f\"Signature input count: {n_sig_inputs}\")\n",
    "assert n_sig_inputs == len(train_cols), \"❌ Signature column count mismatch\"\n",
    "print(\"✅ Signature column count matches train_cols\")\n",
    "\n",
    "print()\n",
    "print(\"=\" * 60)\n",
    "print(\"✅ Cell 12 PASSED — model is safe to point production at.\")\n",
    "print(f\"   Production load URI: {CHAMPION_URI}\")\n",
    "print(\"=\" * 60)"
   ]
